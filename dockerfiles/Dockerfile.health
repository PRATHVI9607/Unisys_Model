FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    kubernetes-asyncio==0.29.0 \
    aioredis==2.0.1 \
    pydantic==2.6.0 \
    aiohttp==3.9.0 \
    prometheus-api-client \
    numpy

COPY agents/ /app/agents/

ENV REDIS_URL=redis://redis-master:6379
ENV DIT_SEC_URL=http://dit-sec-server:8000
ENV PROMETHEUS_URL=http://prometheus:9090
ENV NAMESPACE=kubeheal
ENV LOG_LEVEL=INFO

EXPOSE 8080

CMD ["python", "-m", "agents.health_agent.agent"]