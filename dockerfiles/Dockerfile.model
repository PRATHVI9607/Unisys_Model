FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    torch==2.2.0 \
    torch-geometric==2.5.0 \
    onnxruntime==1.17.0 \
    fastapi==0.110.0 \
    uvicorn==0.27.0 \
    pydantic==2.6.0 \
    aioredis==2.0.1 \
    numpy scipy networkx

COPY models/ /models/

ENV MODEL_PATH=/models/dit_sec_v3.onnx
ENV REDIS_URL=redis://redis-master:6379
ENV LOG_LEVEL=INFO

EXPOSE 8000

CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]