FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    kubernetes-asyncio==29.0.1 \
    redis==5.0.0 \
    pydantic==2.6.0 \
    aiohttp==3.9.0 \
    "numpy<2"

COPY agents/ /app/agents/

ENV REDIS_URL=redis://redis-master:6379
ENV DIT_SEC_URL=http://dit-sec-server:8000
ENV FALCO_GRPC_ADDR=127.0.0.1:5060
ENV ENTROPY_THRESHOLD=7.2
ENV LOG_LEVEL=INFO

EXPOSE 8080

CMD ["python", "-m", "agents.security_agent.agent"]