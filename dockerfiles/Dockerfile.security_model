# Build base first:  docker build -t kubeheal/base:v4 -f dockerfiles/Dockerfile.base .
FROM kubeheal/base:v4
WORKDIR /app
# Only the code + checkpoints the server needs (data/_archive_v3/csv excluded via .dockerignore)
COPY models/ /app/models/
COPY services/ /app/services/
ENV PORT=8002
EXPOSE 8002
CMD ["python", "services/security_model_server/main.py"]
