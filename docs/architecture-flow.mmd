%% ════════════════════════════════════════════════════════════════
%%  KubeHeal v4 — Two Specialized Models + Dependency Correlation
%% ════════════════════════════════════════════════════════════════

    subgraph SRC["☸️ &nbsp;SIGNAL SOURCES — live Kubernetes telemetry"]
        direction LR
        K1["📄 <b>K8s Watch API</b><br/><i>Deployment YAML</i><br/>baseline ⟷ live spec diff"]
        K2["📈 <b>Prometheus</b> · 5s scrape<br/><i>15 metrics × 60 steps</i><br/>cpu·mem·p99·errors·restarts"]
        K3["🔬 <b>Falco eBPF</b><br/><i>syscall traces ≤256</i><br/>open·read·write·rename·mmap"]
        K4["🔥 <b>inotify + entropy</b><br/><i>30-step bits/byte series</i><br/>encryption fingerprint"]
    end

    subgraph AGENTS["🤖 &nbsp;COLLECTOR AGENTS"]
        direction LR
        HA["💚 <b>Health Agent</b><br/>Deployment<br/>watch-reconnect · Prom cache<br/>baseline diff · blast radius"]
        SA["🛡️ <b>Security Agent</b><br/>DaemonSet · hostPID<br/>cgroups v1/v2 · /proc io<br/>entropy · mmap detect"]
    end

    K1 --> HA
    K2 --> HA
    K3 --> SA
    K4 --> SA

%% ─────────────────────── HEALTH MODEL ───────────────────────
    subgraph HM["🩺 &nbsp;HEALTH MODEL &nbsp;·&nbsp; <i>'is this config change harming performance?'</i>"]
        direction TB
        HENC1["🕸️ <b>YAML → GATv2 Encoder</b><br/>3 layers × 8 heads · dynamic attention<br/>parent→child DAG · container pos-tokens<br/><b>→ 128-dim graph embedding</b>"]
        HENC2["🔁 <b>Metrics → BiLSTM Encoder</b><br/>2 stacked bi-directional layers<br/>LayerNorm · fwd+bwd causal context<br/><b>→ 64-dim temporal embedding</b>"]
        HFUSE["🔗 <b>Health Cross-Attention</b><br/>query = YAML · key/value = metrics<br/>'which metric explains this change?'<br/><b>→ 128-dim fused</b>"]
        HHEAD["🎯 <b>Health Output Head</b><br/>4-class softmax + risk regressor<br/>benign · low-risk · perf-degr · critical"]
        HENC1 --> HFUSE
        HENC2 --> HFUSE
        HFUSE --> HHEAD
    end

%% ─────────────────────── SECURITY MODEL ──────────────────────
    subgraph SM["🔒 &nbsp;SECURITY MODEL &nbsp;·&nbsp; <i>'is there an attack in progress?'</i>"]
        direction TB
        SENC1["🔡 <b>Syscalls → Transformer</b><br/>4 heads × 2 layers · Pre-LN · CLS token<br/>sinusoidal PE · long-range deps<br/><b>→ 64-dim event embedding</b>"]
        SENC2["📉 <b>Entropy → Conv1D + SE</b><br/>multi-scale k=3·7·15<br/>squeeze-excitation channel attn<br/><b>→ 64-dim entropy embedding</b>"]
        SFUSE["🔗 <b>Security Cross-Attention</b><br/>query = syscalls · key/value = entropy<br/>'how random were the writes?'<br/><b>→ 64-dim fused</b>"]
        SHEAD["🎯 <b>Security Output Head</b><br/>5-class softmax + risk regressor<br/>benign·suspicious·staging·active·exfil"]
        SENC1 --> SFUSE
        SENC2 --> SFUSE
        SFUSE --> SHEAD
    end

    HA -->|"old_spec + new_spec"| HENC1
    HA -->|"60 × 15 metric window"| HENC2
    SA -->|"syscall sequence + paths"| SENC1
    SA -->|"30-step entropy window"| SENC2

%% ───── per-model outputs ─────
    HHEAD --> HOUT["💚 <b>health_risk</b> [0–1] · 4-class label<br/>field_attention · conformal CI<br/><b>health_embedding · 128-dim</b>"]
    SHEAD --> SOUT["🛡️ <b>sec_risk</b> [0–1] · 5-class label<br/>syscall_attention · entropy spike · CI<br/><b>security_embedding · 64-dim</b>"]

%% ─────────────── DEPENDENCY CORRELATION MODULE ───────────────
    subgraph DCM["🧬 &nbsp;DEPENDENCY CORRELATION MODULE &nbsp;·&nbsp; <b>★ novel contribution ★</b>"]
        direction TB
        DCA["↔️ <b>Bidirectional Cross-Modal Attention</b><br/>health ⇄ security embeddings<br/>health-queries-security &amp; security-queries-health"]
        DCH["📊 <b>Correlation Head</b> → <b>correlation_score [0–1]</b><br/>compound_flag (>0.60)"]
        DCC["🪢 <b>Causal Chain Builder</b><br/>ordered T+Xs event narrative"]
        DCA --> DCH
        DCA --> DCC
    end

    HOUT -->|"128-dim"| DCA
    SOUT -->|"64-dim"| DCA

%% ─────────────── INTERPRETATION LAYER ───────────────
    subgraph INT["💬 &nbsp;INTERPRETATION LAYER &nbsp;·&nbsp; <i>auditable AI</i>"]
        direction LR
        I1["🧮 <b>SHAP Explainer</b><br/>per-field / per-syscall<br/>attributions"]
        I2["🗺️ <b>Field-Name Mapper</b><br/>node-id → K8s path<br/>spec…limits.cpu"]
        I3["📝 <b>NL Summary</b><br/>Claude Haiku<br/>template fallback"]
    end

    HOUT -.-> I1
    SOUT -.-> I1
    I1 --> I2
    I2 --> I3
    DCC --> I3

%% ─────────────── REDIS STREAMS ───────────────
    subgraph RS["🔴 &nbsp;REDIS STREAMS — consumer groups"]
        direction LR
        RS1["health.events"]
        RS2["security.events"]
        RS3["dcm.events"]
        RS4["actions"]
    end

    HOUT --> RS1
    SOUT --> RS2
    DCH --> RS3
    I3 --> RS3

%% ─────────────── FUSION AGENT v4 ───────────────
    subgraph FA["⚖️ &nbsp;FUSION AGENT v4 — three-signal decision engine"]
        direction TB
        FIN["📥 reads <b>health_risk · sec_risk · correlation_score</b>"]
        FPOL["🧠 <b>Pure Decision Policy</b><br/>tier × (prod 1.20 · staging 1.00 · dev 0.70)<br/>compound ×1.15 · conformal-CI gate<br/>circuit breakers · burn-in mode"]
        FLOCK["🫀 heartbeat incident lock<br/>10s TTL · 3s refresh"]
        FIN --> FPOL --> FLOCK
    end

    RS1 --> FIN
    RS2 --> FIN
    RS3 --> FIN

%% ─────────────── DECISIONS ───────────────
    subgraph DEC["🎬 &nbsp;ACTIONS"]
        direction LR
        A1["🛑 <b>AUTO-KILL</b><br/>pod del + PV quarantine"]
        A2["🩹 <b>AUTO-PATCH</b><br/>canary kubectl patch"]
        A3["🙋 <b>HUMAN</b><br/>kill / patch approval"]
        A4["👁️ <b>OBSERVE</b><br/>monitor ×3"]
        A5["✅ <b>BENIGN</b><br/>ack + continue"]
    end

    FLOCK --> A1
    FLOCK --> A2
    FPOL --> A3
    FPOL --> A4
    FPOL --> A5

    DASH["📊 <b>Dashboard</b> · WebSocket live feed<br/>3 model cards · DCM gauge · causal chain · NL summary"]
    A1 --> DASH
    A2 --> DASH
    A3 --> DASH
    RS4 --> DASH
    I3 -.-> DASH

