# Copy to kubeheal-secrets.yaml and fill in. NEVER commit the real key.
#   kubectl create secret generic kubeheal-secrets -n kubeheal \
#     --from-literal=anthropic-api-key=sk-ant-xxxx
apiVersion: v1
kind: Secret
metadata:
  name: kubeheal-secrets
  namespace: kubeheal
type: Opaque
stringData:
  anthropic-api-key: "REPLACE_WITH_YOUR_ANTHROPIC_API_KEY"
